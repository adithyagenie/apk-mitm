{
  "name": "apk-mitm",
  "description": "A CLI application that automatically prepares Android APK files for HTTPS inspection",
  "main": "dist/index.js",
  "repository": "shroudedcode/apk-mitm",
  "keywords": [
    "cli",
    "reverse engineering",
    "android",
    "apk",
    "mitm",
    "certificate pinning"
  ],
  "version": "1.3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "tsc",
    "watch": "tsc --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "prepack": "pnpm build"
  },
  "bin": "dist/cli.js",
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "@tybys/cross-zip": "^3.1.0",
    "chalk": "^5.6.2",
    "env-paths": "^4.0.0",
    "escape-string-regexp": "^5.0.0",
    "execa": "^9.6.1",
    "follow-redirects": "^1.15.11",
    "globby": "^16.2.0",
    "listr": "^0.14.3",
    "rxjs": "^7.8.2",
    "tempy": "^3.2.0",
    "xml-js": "^1.6.11",
    "yargs-parser": "^22.0.0"
  },
  "devDependencies": {
    "@types/follow-redirects": "^1.14.4",
    "@types/listr": "^0.14.10",
    "@types/node": "25.5.0",
    "@types/yargs-parser": "^21.0.3",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "rxjs": "^7.1.0"
    }
  }
}
